# Money Printer — Environment Configuration
# Copy this file to .env and fill in every value
# NEVER commit .env to git

# ── RPC Connection ────────────────────────────────────────────────────────────
# Use your dedicated Base node private IP (same AWS VPC) for lowest latency
BASE_WS_URL=ws://10.0.1.50:8546

# Public fallback (higher latency — use only if private node is down):
# BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Contracts ─────────────────────────────────────────────────────────────────
ARBITRAGE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── Wallets ───────────────────────────────────────────────────────────────────
# Bot wallet — executes all trades, holds working capital
PRIVATE_KEY=0xYOUR_BOT_WALLET_PRIVATE_KEY

# Treasury destination wallets (receive USDC distributions every 6 hours)
# These should be separate wallets from the bot wallet
SPENDING_WALLET=0xYOUR_SPENDING_WALLET_ADDRESS     # Link to Coinbase Card / Crypto.com Visa
OVERHEAD_WALLET=0xYOUR_OVERHEAD_WALLET_ADDRESS     # Server & infrastructure costs Visa
STAKING_WALLET=0xYOUR_STAKING_WALLET_ADDRESS       # Staking pool + emergency fund

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Get token from @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhiJklMnopQrstUvwXyz
TELEGRAM_CHAT_ID=123456789

# ── Email Reports (SendGrid) ──────────────────────────────────────────────────
# Free tier at sendgrid.com — 100 emails/day free
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
REPORT_EMAIL=your@email.com

# ── AI Oversight (Claude API) ─────────────────────────────────────────────────
# Get from console.anthropic.com
# Used for: error diagnosis, fix proposals, staking optimisation
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here

# ── Paths ─────────────────────────────────────────────────────────────────────
PROJECT_DIR=/home/ubuntu/money-printer
LOG_DIR=/home/ubuntu/money-printer/logs
