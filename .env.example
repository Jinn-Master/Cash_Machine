# =============================================================================
#  Cash Machine — Environment Configuration
#  Copy this to .env and fill in every value.
#  NEVER commit .env to git — it's in .gitignore
# =============================================================================

# ── Chain Selection ───────────────────────────────────────────────────────────
# Set CHAIN=base or CHAIN=arbitrum to choose which chain to run on.
# You can also run both simultaneously by starting two bot instances.
CHAIN=base

# ── RPC Connections ───────────────────────────────────────────────────────────

# Base Mainnet — WebSocket (required for Sync event subscriptions)
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Base HTTP fallback (for contract deployment / verification)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arbitrum One — WebSocket
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Arbitrum HTTP fallback
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Testnets (optional — for testing before mainnet)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Deployed Contract Addresses ───────────────────────────────────────────────
# Fill in after running: make deploy-base / make deploy-arb
ARBITRAGE_CONTRACT_ADDRESS=0xYOUR_BASE_CONTRACT_ADDRESS
ARBITRUM_CONTRACT_ADDRESS=0xYOUR_ARBITRUM_CONTRACT_ADDRESS

# ── Bot Wallet ────────────────────────────────────────────────────────────────
# This wallet executes all trades and pays gas.
# Needs: ETH for gas, USDC/WETH as working capital.
PRIVATE_KEY=0xYOUR_BOT_WALLET_PRIVATE_KEY

# ── Treasury Destination Wallets ──────────────────────────────────────────────
# Profits are distributed to these wallets every 6 hours.
# These should be SEPARATE from the bot wallet.
SPENDING_WALLET=0xYOUR_SPENDING_WALLET_ADDRESS   # → Coinbase Card / Visa
OVERHEAD_WALLET=0xYOUR_OVERHEAD_WALLET_ADDRESS   # → Server & infra costs
STAKING_WALLET=0xYOUR_STAKING_WALLET_ADDRESS     # → Staking pool / emergency fund

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Get token: message @BotFather on Telegram → /newbot
# Get chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhiJklMnopQrstUvwXyz
TELEGRAM_CHAT_ID=123456789

# ── Email Reports (SendGrid) ──────────────────────────────────────────────────
# Free tier: 100 emails/day — sign up at sendgrid.com
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
REPORT_EMAIL=your@email.com

# ── AI Oversight ────────────────────────────────────────────────────────────────
# Choose backend: "local" (OWL/Hermes on your machine) or "claude" (Anthropic API)
# Default: local (zero cost, works offline)
AI_BACKEND=local

# Local AI (used when AI_BACKEND=local)
# URL where your local AI is running (Ollama, Hermes, etc.)
LOCAL_AI_URL=http://localhost:11434
LOCAL_AI_MODEL=llama3

# Claude API (used when AI_BACKEND=claude)
# Get from console.anthropic.com
CLAUDE_API_KEY=sk-ant...here

# ── Block Explorer API Keys (for contract verification) ───────────────────────
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY      # basescan.org → My Account → API Keys
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY      # arbiscan.io  → My Account → API Keys

# ── Kill Switch ────────────────────────────────────────────────────────────────
# Set to "true" to pause all trading on startup. Bot monitors continue running
# but no trades execute. Useful for safe deployment and testing.
# Remove or set to "false" to enable trading.
KILL_SWITCH=false

# ── Paths ─────────────────────────────────────────────────────────────────────
PROJECT_DIR=/home/ubuntu/Cash_Machine
LOG_DIR=/home/ubuntu/Cash_Machine/logs
